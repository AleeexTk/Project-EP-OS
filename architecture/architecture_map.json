{
  "version": "1.0",
  "comment": "EvoPyramid OS Topology Definitions",
  "modules": {
    "Z17_GLOBAL_NEXUS": { "layer": "alpha", "sector": "spine", "role": "Top orchestrator" },
    "Z16_NEXUS_ROUTER": { "layer": "alpha", "sector": "spine", "role": "Sync task dispatcher" },
    "Z14_POLICY_BUS": { "layer": "alpha", "sector": "spine", "role": "ZBus canonical source" },
    "Z14_AUTO_CORRECTOR": { "layer": "alpha", "sector": "spine", "role": "Self-healing" },
    "B1_PROJECT_CORTEX": { "layer": "beta", "sector": "kernel", "role": "MinHash+LSH Memory" },
    "B2_SYNTHESIS_AGENT": { "layer": "beta", "sector": "orchestrator", "role": "Task Translator" },
    "B2_LLM_ORCHESTRATOR": { "layer": "beta", "sector": "orchestrator", "role": "Multi-provider dispatch" },
    "B4_COGNITIVE_BRIDGE": { "layer": "beta", "sector": "cognitive", "role": "Long-term Memory Gateway" },
    "D_INTERFACE_API": { "layer": "beta", "sector": "interface", "role": "FastAPI entry point" },
    "EXTERNAL_CHATGPT": { "layer": "external", "sector": "aio", "role": "Architecture Formalizer & Governance Auditor" },
    "EXTERNAL_CODEX":   { "layer": "external", "sector": "ci",  "role": "CI PR Reviewer" },
    "EXTERNAL_TELEGRAM":{ "layer": "external", "sector": "ui",  "role": "User notification channel" },
    "FRONTEND_UI":      { "layer": "external", "sector": "ui",  "role": "React + Three.js Web Control Plane" }
  },
  "routes": {
    "EXECUTION_CASCADE": [
      "Z17_GLOBAL_NEXUS",
      "Z16_NEXUS_ROUTER",
      "B2_SYNTHESIS_AGENT",
      "B2_LLM_ORCHESTRATOR"
    ],
    "HEALING_PIPELINE": [
      "Z14_POLICY_BUS",
      "Z14_AUTO_CORRECTOR",
      "B4_COGNITIVE_BRIDGE"
    ],
    "COGNITIVE_RECALL": [
      "B2_SYNTHESIS_AGENT",
      "B4_COGNITIVE_BRIDGE",
      "B1_PROJECT_CORTEX"
    ],
    "AIO_GOVERNANCE_ROUTE": [
      "EXTERNAL_CHATGPT",
      "Z17_GLOBAL_NEXUS"
    ],
    "CI_REVIEW_ROUTE": [
      "EXTERNAL_CODEX",
      "Z14_POLICY_BUS"
    ],
    "NOTIFICATION_ROUTE": [
      "D_INTERFACE_API",
      "EXTERNAL_TELEGRAM"
    ]
  },
  "bridges": {
    "ZBUS_BRIDGE": ["Z14_POLICY_BUS", "B2_SYNTHESIS_AGENT"],
    "WEB_WS_BRIDGE": ["B2_LLM_ORCHESTRATOR", "FRONTEND_UI"],
    "AIO_BRIDGE": ["EXTERNAL_CHATGPT", "Z17_GLOBAL_NEXUS"],
    "CI_BRIDGE":  ["EXTERNAL_CODEX",   "Z14_POLICY_BUS"]
  }
}
