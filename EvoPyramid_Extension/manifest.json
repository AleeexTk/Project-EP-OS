{
  "manifest_version": 3,
  "name": "EvoPyramid OS - Nexus Link",
  "version": "1.0",
  "description": "Fail-safe offline-capable link between EvoPyramid OS and Web AI models.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "*://*.chatgpt.com/*",
    "https://grok.com/*",
    "https://*.anthropic.com/*",
    "https://aistudio.google.com/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.chatgpt.com/*",
        "https://grok.com/*",
        "https://aistudio.google.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "EvoPyramid Nexus"
  }
}
