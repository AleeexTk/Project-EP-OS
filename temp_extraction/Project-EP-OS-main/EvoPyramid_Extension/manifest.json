{
  "manifest_version": 3,
  "name": "EvoPyramid OS - Nexus Link",
  "version": "2.0",
  "description": "Universal bridge between EvoPyramid OS and all major LLM web interfaces.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "*://*.chatgpt.com/*",
    "*://*.claude.ai/*",
    "https://grok.com/*",
    "https://aistudio.google.com/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.chatgpt.com/*",
        "*://*.claude.ai/*",
        "https://grok.com/*",
        "https://aistudio.google.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "EvoPyramid Nexus"
  }
}
